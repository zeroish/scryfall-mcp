#!/bin/bash
# script/server
#
# Start the development server with the FastMCP inspector (hot-reload).
# Builds the dev image (which includes Node.js for the inspector UI)
# and the production image, then launches the inspector.
# Inspector UI: http://localhost:6274

set -e
cd "$(dirname "$0")/.."

script/update

echo "==> Building dev image..."
docker compose build dev

echo "==> Starting dev server (FastMCP inspector at http://localhost:${INSPECTOR_PORT:-6274})..."
docker compose up dev
