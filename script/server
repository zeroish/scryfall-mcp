#!/bin/bash
# script/server
#
# Start the development server in SSE mode with source mounted.
# Same image you ship — edit scryfall_mcp.py, then restart:
#   docker compose restart dev
#
# Connect any MCP client to http://localhost:8000

set -e
cd "$(dirname "$0")/.."

script/update

echo "==> Starting dev server (SSE mode at http://localhost:${DEV_PORT:-8000})..."
docker compose up dev
