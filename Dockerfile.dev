# Dev-only image — adds Node.js for the FastMCP Inspector UI.
# Production image stays on DHI (zero CVE). This is intentionally a heavier image
# because the inspector requires npx to launch its React-based UI.
FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends nodejs npm \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --no-compile -r requirements.txt

# Source is mounted as a volume at runtime — no COPY needed.
CMD ["fastmcp", "dev", "inspector", "scryfall_mcp.py"]
